# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Site Audit AI"
APP_VERSION="0.1.0"
DEBUG=false

# CORS: add your EC2 public IP or domain (no trailing slash)
# Example: ["http://54.123.45.67"] or ["https://yourdomain.com"]
ALLOWED_ORIGINS=["http://your-ec2-ip-or-domain"]

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
# Uses the `postgres` Docker Compose service name as the hostname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/site_audit

# ── Redis ──────────────────────────────────────────────────────────────────────
# Uses the `redis` Docker Compose service name as the hostname
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Playwright ─────────────────────────────────────────────────────────────────
PLAYWRIGHT_TIMEOUT_MS=30000
MAX_CRAWL_PAGES=10

# ── Lighthouse ─────────────────────────────────────────────────────────────────
LIGHTHOUSE_BINARY=lighthouse
LIGHTHOUSE_TIMEOUT_MS=60000
# /usr/bin/chromium is installed by the Dockerfile for use inside Docker.
# Leave empty to let Lighthouse auto-detect (useful for local dev without Docker).
LIGHTHOUSE_CHROME_PATH=/usr/bin/chromium

# ── Jobs ───────────────────────────────────────────────────────────────────────
JOB_EXPIRY_SECONDS=86400
