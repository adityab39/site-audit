# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Site Audit AI"
APP_VERSION="0.1.0"
DEBUG=false

# JSON array of allowed CORS origins (frontend dev server + API itself)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/site_audit

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Playwright ─────────────────────────────────────────────────────────────────
PLAYWRIGHT_TIMEOUT_MS=30000
MAX_CRAWL_PAGES=10

# ── Lighthouse ─────────────────────────────────────────────────────────────────
LIGHTHOUSE_BINARY=lighthouse
LIGHTHOUSE_TIMEOUT_MS=60000
# Absolute path to Chrome/Chromium for Lighthouse to use.
# /usr/bin/chromium  → system package (default inside Docker)
# Leave empty to let Lighthouse auto-detect.
LIGHTHOUSE_CHROME_PATH=/usr/bin/chromium

# ── Jobs ───────────────────────────────────────────────────────────────────────
JOB_EXPIRY_SECONDS=86400
